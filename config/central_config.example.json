{
  "check_interval_seconds": 30,
  "heartbeat_stale_seconds": 90,
  "require_heartbeat": false,

  "alert_after_failures": 3,
  "critical_alert_after_failures": 2,

  "log_path": "C:\\P3DMonitor\\logs\\central_monitor.log",

  "active_hours": {
    "enabled": true,
    "start": "07:00",
    "end": "18:00"
  },

  "debounce": {
    "_comment": "How many consecutive failed checks before confirming a failure state",
    "p3d_failure_threshold": 3,
    "p3d_recovery_threshold": 2,
    "heartbeat_failure_threshold": 3,
    "heartbeat_recovery_threshold": 2,
    "ping_failure_threshold": 3,
    "ping_recovery_threshold": 2,
    "vnc_failure_threshold": 3,
    "vnc_recovery_threshold": 2
  },

  "alerts": {
    "email_enabled": false,
    "sms_email_gateway_enabled": false,
    "recipients": [
      "technician@example.com"
    ],
    "smtp_host": "smtp.example.com",
    "smtp_port": 587,
    "smtp_from": "monitor@example.com"
  }
}
